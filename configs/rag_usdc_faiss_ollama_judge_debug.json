{
  "experiment_name": "rag_usdc_faiss_ollama_judge_debug",
  "condition": "rag",
  "models": {
    "test_agent": {
      "backend": "ollama",
      "model_name": "qwen2.5:3b",
      "temperature": 0.7,
      "max_tokens": 180
    },
    "adversary_agent": {
      "backend": "ollama",
      "model_name": "qwen2.5:3b",
      "temperature": 0.7,
      "max_tokens": 180
    },
    "judge": {
      "backend": "ollama",
      "model_name": "qwen2.5:3b",
      "temperature": 0.0,
      "max_tokens": 160
    }
  },
  "retrieval": {
    "backend": "faiss",
    "index_path": "data/rag_indexes/usdc_selected.faiss",
    "metadata_path": "data/rag_indexes/usdc_selected_metadata.json",
    "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
    "top_k": 3,
    "search_k": 100
  },
  "rounds": 5,
  "seeds": [42],
  "topics": [
    {
      "name": "climate_change",
      "question": "Should governments take stronger action against climate change?"
    }
  ],
  "stance_pairs": [
    {
      "test_agent_stance": "pro",
      "test_agent_stance_score": 2,
      "adversary_stance": "contra",
      "adversary_stance_score": -2
    },
    {
      "test_agent_stance": "contra",
      "test_agent_stance_score": -2,
      "adversary_stance": "pro",
      "adversary_stance_score": 2
    }
  ],
  "output_dir": "outputs/transcripts"
}