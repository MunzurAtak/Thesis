{
  "experiment_name": "rag_usdc_ollama_judge_smoke_test",
  "condition": "rag",
  "models": {
    "test_agent": {
      "backend": "ollama",
      "model_name": "qwen2.5:3b",
      "temperature": 0.7,
      "max_tokens": 120
    },
    "adversary_agent": {
      "backend": "ollama",
      "model_name": "qwen2.5:3b",
      "temperature": 0.7,
      "max_tokens": 120
    },
    "judge": {
      "backend": "ollama",
      "model_name": "qwen2.5:3b",
      "temperature": 0.0,
      "max_tokens": 160
    }
  },
  "retrieval": {
    "backend": "simple",
    "corpus_path": "data/rag_corpus/usdc_selected_rag_corpus.json",
    "top_k": 3
  },
  "rounds": 1,
  "seeds": [42],
  "topics": [
    {
      "name": "climate_change",
      "question": "Should governments take stronger action against climate change?"
    }
  ],
  "stance_pairs": [
    {
      "test_agent_stance": "pro",
      "test_agent_stance_score": 2,
      "adversary_stance": "contra",
      "adversary_stance_score": -2
    },
    {
      "test_agent_stance": "contra",
      "test_agent_stance_score": -2,
      "adversary_stance": "pro",
      "adversary_stance_score": 2
    }
  ],
  "output_dir": "outputs/transcripts"
}