# --- Data ---
# Regenerable / large intermediates are ignored; the datasets used by the
# experiment (raw USDC pickles + zipped CSV, RAG corpus, FAISS index, LoRA
# training data) are committed. See DATA.md.
data/processed/
data/rag_indices/

# Ignore everything in data/raw EXCEPT the committed dataset files.
# The uncompressed 174 MB USDC_Stance.csv stays out (over GitHub's file limit);
# it is provided zipped as USDC_Stance_csv.zip.
data/raw/*
!data/raw/USDC_Stance.pkl
!data/raw/USDC_Dogmatism.pkl
!data/raw/USDC_Stance_csv.zip
